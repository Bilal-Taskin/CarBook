@model List<ResultAllBlocksWithAuthorDto>

<div class="col-xl-6">
    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Last Blocks</h4>
            <p class="card-subtitle mb-4 font-size-13">
                Last Block and Authors
            </p>

            <div class="table-responsive">
                <table class="table table-borderless table-hover table-centered table-nowrap mb-0">
                    <tr>
                        <th>Author</th>
                        <th>Blog Title</th>
                        <th>Show Block</th>
                    </tr>
                    <tbody>
                        @foreach (var item in Model)
                        {

                            <tr>
                                <td>
                                    <h5 class="font-size-15 mb-1 font-weight-normal">
                                        @item.authorName
                                    </h5>
                                </td>
                                <td>
                                    <h5 class="font-size-15 mb-1 font-weight-normal">@item.title</h5>

                                </td>
                                <td>
                                    <h5 class="font-size-15 mb-1 font-weight-normal">
                                        <a href="/Block/BlockDetail/@item.blockID" class="btn btn-primary">Show</a>
                                    </h5>

                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>

        </div> <!-- end card-body-->
    </div> <!-- end card-->
</div>
