@model List<ResultCarPricingListWithModelDto>
<div class="col-xl-6">
    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Rent Car Prices</h4>
            <p class="card-subtitle mb-4 font-size-13">
                Some cars prices
            </p>

            <div class="table-responsive">
                <table class="table table-centered table-hover table-xl mb-0" id="recent-orders">
                    <thead>
                        <tr>
                            <th class="border-top-0">Brand</th>
                            <th class="border-top-0">Model</th>
                            <th class="border-top-0">Daily Price</th>
                            <th class="border-top-0">Weekly Price </th>
                            <th class="border-top-0">Monthly Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-truncate">@item.Brand </td>
                                <td class="text-truncate">@item.model </td>
                                 <td class="text-truncate">@item.dailyAmount ₺</td>
                                 <td class="text-truncate">@item.weeklyAmount ₺</td>
                                 <td class="text-truncate">@item.monthlyAmount ₺</td>
                            </tr>
                        }



                    </tbody>
                </table>
            </div>

        </div> <!-- end card-body-->
    </div> <!-- end card-->
</div>
