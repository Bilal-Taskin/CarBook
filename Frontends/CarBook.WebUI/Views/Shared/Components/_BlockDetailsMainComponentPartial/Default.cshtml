@model GetBlockById 
 @* _BlockDetailsMainComponentPartial  sayfasının default'u*@
<div class="col-md-8 ftco-animate">
    <h2 class="mb-3">@Model.Title</h2>
    <p>@Model.BlockDescription</p>
   
    @await Component.InvokeAsync("_BlogDetailCloudTagByBlogComponentPartial", new { id = ViewBag.blockId })

    @await Component.InvokeAsync("_BlockDetailsAboutAuthorComponentPartial", new { id = ViewBag.blockId })

      <div class="pt-5 mt-5">
        
        <h3 class="mb-5">@ViewBag.commentCount </h3>
      
        @await Component.InvokeAsync("_CommentListByBlockComponentPartial", new { id = ViewBag.blockId })

       @*  @await Component.InvokeAsync("_AddCommentCopmonentPartial") *@
        @await Html.PartialAsync("~/Views/Block/AddComment.cshtml", new { id = ViewBag.blockId })
       
     </div>

</div>
